@article{Lipman2019, 
  year    = {2019}, 
  title   = {Magmato-tectonic links: Ignimbrite calderas, regional dike swarms, and the transition from arc to rift in the southern rocky mountains}, 
  author  = {Lipman, Peter W and Zimmerer, Matthew J}, 
  journal = {Geosphere}, 
  doi     = {10.1130/ges02068.1}, 
  pages   = {1893--1926}, 
  volume  = {15}, 
  note    = {The purpose of this study is to capture the temporal, spatial, and chemical evolution of the Dulce Dikes, a swarm of north-south trending dikes that stretch
for {\textasciitilde} 125 km in northern New Mexico/Southern Colorado. This is done to try and
put the Dike swarm in context of the San Juan Volcanic field and specifically
the polycyclic Platoro Caldera, which was one of the longest active calderas in
the Southern Rocky Mountain Volcanic field and was the locus that mainatained
volcanism the longest after collapse {\textasciitilde}  29 Ma.

Their analysis reveals a trend where dikes become more mafic and younger the
further you get from the caldera nad associated granitic intrusions, and that
with time the dikes tend to realign from geometry's indicating a stress filed
dominated by conical structures of volcanos and calderas to the north-south
trending extensional stresses of the present day rio-grande rift.

This is interesting because, while it has often been reckognized that ignimbrite
flareups tend to be associated with the onset of regional extension. This paper
shows that the large eruptions actually proceeded extension. It seems like most
arcs follow this trend both mechanically and compositionally.}
}

